# =============================================================================
# Python .gitignore — Server Monitoring System
# =============================================================================

# ---------------------------------------------------------------------------
# Python byte-compiled / optimized / DLL files
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ---------------------------------------------------------------------------
# Operating system files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Logs (keep the directory, ignore contents)
# ---------------------------------------------------------------------------
logs/*.log
logs/*.log.*

# ---------------------------------------------------------------------------
# Generated reports (keep the directory, ignore generated files)
# ---------------------------------------------------------------------------
reports/*.html
reports/*.pdf

# ---------------------------------------------------------------------------
# Metric data (keep the directory, ignore collected data)
# ---------------------------------------------------------------------------
metrics/*.json

# ---------------------------------------------------------------------------
# Testing and coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---------------------------------------------------------------------------
# Jupyter Notebook checkpoints
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
