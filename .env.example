# =============================================================================
# DEVOPS ENGINEERS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Clerk Authentication
# Get your keys at: https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Webhook Secret (for user sync with Supabase)
# Get from Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# Optional: Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# -----------------------------------------------------------------------------
# Supabase Database
# Get your keys at: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Resend Email (Optional)
# Get your API key at: https://resend.com/api-keys
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_...
# EMAIL_FROM=DevOps Engineers <noreply@devopsengineer.com>

# -----------------------------------------------------------------------------
# Sentry Error Tracking (Optional)
# Get your DSN at: https://sentry.io → Project Settings → Client Keys
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
